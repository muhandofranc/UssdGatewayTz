# UssdGatewayTz — env template.
# Copy to .env (gitignored) and fill in.
#
# Compose env_file: docker-compose substitutes ${VAR} at parse-time
# from this file + ./.env. Keep each comment on its OWN line — Compose
# does NOT strip trailing `# comment` after a value.

# ---- Postgres (EXTERNAL host) --------------------------------------
# The DB is NOT bundled in the gateway compose; point at your Tanzania
# Postgres host. Schema is applied once via:
#     docker compose exec -T gateway python -m app.db_init
USSD_PG_HOST=10.0.0.5
USSD_PG_PORT=5432
USSD_PG_USER=ussd_gw
USSD_PG_PASSWORD=CHANGE_ME
USSD_PG_DB=ussd_gateway_tz
# disable | prefer | require | verify-ca | verify-full
USSD_PG_SSLMODE=prefer

# ---- Gateway tuning -----------------------------------------------
# Default per-handler outbound timeout when a shortcode row doesn't
# set timeout_secs. MNO USSD timeouts are typically 5–10s; keep this
# comfortably below to leave headroom for our own latency.
USSD_HANDLER_DEFAULT_TIMEOUT_SECS=5

# DEBUG | INFO | WARNING | ERROR
USSD_LOG_LEVEL=INFO

# ---- Halotel (async-outbound SOAP) --------------------------------
# Halotel is the only MNO whose menu is pushed OUT on a separate HTTP
# call (we ack inbound immediately, then POST the menu back). Needs
# credentials in BOTH directions:
#   inbound  — what Halotel sends us in the SOAP body (we verify)
#   outbound — what WE send Halotel in the SOAP body (provisioned by them)
HALOTEL_INBOUND_USER=CHANGE_ME
HALOTEL_INBOUND_PASS=CHANGE_ME
HALOTEL_OUTBOUND_URL=https://halotel-ussdgw.example/InsertMO
HALOTEL_OUTBOUND_USER=CHANGE_ME
HALOTEL_OUTBOUND_PASS=CHANGE_ME
# Echoed in <ussdgw_id> on our outbound when the inbound didn't carry it.
HALOTEL_USSDGW_ID=1
# httpx timeout on the outbound POST — keep < the USSD-session budget.
HALOTEL_OUTBOUND_TIMEOUT_SECS=4

# ---- Host port mapping (docker-compose) ----------------------------
# Bind the gateway to a different host port if 8080 is taken.
USSD_LISTEN_PORT_HOST=8080
# Echo handler used by tests/smoke (drop the echo service from compose
# in production).
ECHO_HANDLER_PORT_HOST=8081

# ---- Dashboard (Next.js, Phase 3) ---------------------------------
# 48+ chars, ≥16 distinct chars. Generate with:
#   openssl rand -base64 64 | tr -d '\n=/+'
# Rotate to invalidate every live session.
SESSION_SECRET=CHANGE_ME_48_PLUS_RANDOM_CHARS_WITH_VARIETY_____________
SESSION_COOKIE_NAME=ussd_gw_dashboard_session
SESSION_TTL_SECONDS=28800
# Dev only — set to 1 to allow the cookie over plain HTTP. Unset in prod.
SESSION_COOKIE_INSECURE=
DASHBOARD_PORT_HOST=3000
DASHBOARD_PG_POOL_MAX=10

# ---- Build-time cache buster --------------------------------------
APT_REFRESH=build
