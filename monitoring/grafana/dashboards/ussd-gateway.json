{
  "annotations": { "list": [] },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "iteration": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "USSD activity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Hops per second — by MNO",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (operator) (rate(ussd_hop_total[1m]))",
          "legendFormat": "{{operator}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hop latency — p50 / p95 / p99 (all MNOs)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(ussd_hop_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ussd_hop_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(ussd_hop_latency_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Handler errors — by class",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (error_class) (rate(ussd_handler_errors_total[1m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hop latency — p95 by MNO",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operator) (rate(ussd_hop_latency_seconds_bucket[5m])))",
          "legendFormat": "{{operator}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP + writer",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "HTTP requests / s — by route + status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (route, status) (rate(ussd_http_requests_total[1m]))",
          "legendFormat": "{{route}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Session-log writer queue depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "ussd_session_log_queue_depth", "legendFormat": "depth", "refId": "A" },
        { "expr": "rate(ussd_session_log_rows_dropped_total[1m])", "legendFormat": "dropped/s", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Host + containers",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "type": "timeseries",
      "title": "Host CPU utilisation %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host RAM utilisation %",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk usage % — real filesystems",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|nsfs|autofs|devpts|devtmpfs|proc|sysfs|cgroup2?|configfs|debugfs|fusectl|bpf|hugetlbfs|mqueue|pstore|rpc_pipefs|tracefs|selinuxfs|securityfs|binfmt_misc|iso9660\",mountpoint!~\"/(dev|sys|proc|run|boot|etc|var/lib/docker/.+)($|/.*)\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|nsfs|autofs|devpts|devtmpfs|proc|sysfs|cgroup2?|configfs|debugfs|fusectl|bpf|hugetlbfs|mqueue|pstore|rpc_pipefs|tracefs|selinuxfs|securityfs|binfmt_misc|iso9660\",mountpoint!~\"/(dev|sys|proc|run|boot|etc|var/lib/docker/.+)($|/.*)\"}) * 100",
          "legendFormat": "{{host}} {{mountpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Containers running (by host)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 35 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "count by (host) (container_last_seen{name!=\"\"} > (time() - 60))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-container CPU %",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 35 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "sum by (host, name) (rate(container_cpu_usage_seconds_total{name=~\".+\"}[1m])) * 100",
          "legendFormat": "{{host}} / {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-container memory (RSS)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "container_memory_rss{name=~\".+\"}",
          "legendFormat": "{{host}} / {{name}}",
          "refId": "A"
        }
      ]
    }
  ],
