{
  "annotations": { "list": [] },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "iteration": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "USSD activity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Hops per second — by MNO",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (operator) (rate(ussd_hop_total[1m]))",
          "legendFormat": "{{operator}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hop latency — p50 / p95 / p99 (all MNOs)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(ussd_hop_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ussd_hop_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(ussd_hop_latency_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Handler errors — by class",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (error_class) (rate(ussd_handler_errors_total[1m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hop latency — p95 by MNO",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operator) (rate(ussd_hop_latency_seconds_bucket[5m])))",
          "legendFormat": "{{operator}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP + writer",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "HTTP requests / s — by route + status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (route, status) (rate(ussd_http_requests_total[1m]))",
          "legendFormat": "{{route}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Session-log writer queue depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "ussd_session_log_queue_depth", "legendFormat": "depth", "refId": "A" },
        { "expr": "rate(ussd_session_log_rows_dropped_total[1m])", "legendFormat": "dropped/s", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Host + containers",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "type": "timeseries",
      "title": "Host CPU utilisation %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host RAM utilisation %",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk usage % — real filesystems",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|nsfs|autofs|devpts|devtmpfs|proc|sysfs|cgroup2?|configfs|debugfs|fusectl|bpf|hugetlbfs|mqueue|pstore|rpc_pipefs|tracefs|selinuxfs|securityfs|binfmt_misc|iso9660\",mountpoint!~\"/(dev|sys|proc|run|boot|etc|var/lib/docker/.+)($|/.*)\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|nsfs|autofs|devpts|devtmpfs|proc|sysfs|cgroup2?|configfs|debugfs|fusectl|bpf|hugetlbfs|mqueue|pstore|rpc_pipefs|tracefs|selinuxfs|securityfs|binfmt_misc|iso9660\",mountpoint!~\"/(dev|sys|proc|run|boot|etc|var/lib/docker/.+)($|/.*)\"}) * 100",
          "legendFormat": "{{host}} {{mountpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Containers running (by host)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 35 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "count by (host) (container_last_seen{name!=\"\"} > (time() - 60))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-container CPU %",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 35 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "sum by (host, name) (rate(container_cpu_usage_seconds_total{name=~\".+\"}[1m])) * 100",
          "legendFormat": "{{host}} / {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-container memory (RSS)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "container_memory_rss{name=~\".+\"}",
          "legendFormat": "{{host}} / {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Container health — filtered host ($host)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }
    },
    {
      "type": "table",
      "title": "Containers on $host — last seen (fresh = green, stale = red)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 52 },
      "datasource": "Prometheus",
      "description": "Seconds since cAdvisor last saw the container. A value climbing above ~60 s means either the container stopped or cAdvisor lost sight of it.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 60 }
            ]
          },
          "custom": {
            "cellOptions": { "type": "color-background" },
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "custom.width", "value": 320 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "image" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "custom.width", "value": 320 }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns", "keepLabels": ["name", "image"] }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true,
              "service": true,
              "id": true,
              "__name__": true
            },
            "renameByName": {
              "Value": "seconds since last seen"
            },
            "indexByName": {
              "name":  0,
              "image": 1,
              "Value": 2
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "time() - container_last_seen{host=\"$host\", name!=\"\"}",
          "legendFormat": "{{name}}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container restart rate on $host",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 64 },
      "datasource": "Prometheus",
      "description": "Restarts / sec per container. Any non-zero blip = something crashed or was manually bounced. Requires the container to expose a start-count metric via cAdvisor's `container_start_time_seconds`.",
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_start_time_seconds{host=\"$host\", name!=\"\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container OOM events on $host",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 64 },
      "datasource": "Prometheus",
      "description": "Out-of-memory kills. Any non-zero value means the kernel killed the container's PID for memory pressure — worth digging into.",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_oom_events_total{host=\"$host\", name!=\"\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ussd", "gateway"],
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": "Prometheus",
        "query": { "query": "label_values(container_last_seen, host)", "refId": "host" },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": { "text": "172.16.0.104", "value": "172.16.0.104" },
        "description": "Filter the Container health panels to a single host. Populated live from cAdvisor scrapes; if a host is missing here, its cAdvisor isn't running or its scrape target is DOWN."
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "USSD Gateway — overview",
  "uid": "ussd-gateway-overview",
  "version": 1,
  "weekStart": ""
}
