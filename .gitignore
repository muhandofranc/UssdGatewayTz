# Local docker env — secrets. Never commit.
.env
docker-compose.yml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
docker-compose.yml

# Node / Next.js — never commit build artefacts or installed deps
node_modules/
.next/
dashboard/tsconfig.tsbuildinfo

# Alertmanager runtime secrets — NEVER commit. Contains SMTP
# password + any future integration keys (Slack webhook, PagerDuty
# token, etc.). Files live inside the ignored directory; the
# directory itself is kept via .keep only for the docker mount.
monitoring/alertmanager/secrets/*
!monitoring/alertmanager/secrets/.keep
!monitoring/alertmanager/secrets/README.md
