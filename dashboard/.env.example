# UssdGatewayTz Dashboard — env template.
# Copy to .env (gitignored) and fill in.

# ---- Postgres (shared with the gateway) ---------------------------
# Same DB / creds as the gateway — the dashboard reads ussd_session_logs
# and portal_users from the same place.
USSD_PG_HOST=127.0.0.1
USSD_PG_PORT=5410
USSD_PG_USER=ussd_gw
USSD_PG_PASSWORD=CHANGE_ME
USSD_PG_DB=ussd_gateway_tz
USSD_PG_SSLMODE=disable

# Connection pool size for the Node server.
DASHBOARD_PG_POOL_MAX=10

# ---- Session JWT --------------------------------------------------
# 48+ chars, ≥16 distinct chars. Generate with:
#   openssl rand -base64 64 | tr -d '\n='
# Rotate to invalidate every live session.
SESSION_SECRET=CHANGE_ME_48_PLUS_RANDOM_CHARS_WITH_VARIETY_____________

# Cookie name (default fine in most setups).
SESSION_COOKIE_NAME=ussd_gw_dashboard_session

# Session lifetime (seconds). 28800 = 8 hours.
SESSION_TTL_SECONDS=28800

# Set to 1 to allow the cookie over plain HTTP (NON-production only).
# Leave blank / 0 in prod — the cookie demands Secure by default.
SESSION_COOKIE_INSECURE=

# ---- Host port mapping --------------------------------------------
DASHBOARD_PORT_HOST=3000
